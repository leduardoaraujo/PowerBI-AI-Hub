# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here

# Anthropic/Claude Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Backend API security (optional but recommended)
BACKEND_API_KEY=

# MCP Configuration
MCP_EXE_PATH=mcp_bin/powerbi-modeling-mcp.exe
MCP_DEFAULT_MODE=readonly
MCP_START_ARGS=["--start"]
MCP_REQUEST_TIMEOUT=30.0
MCP_HEALTH_CHECK_INTERVAL=15.0
MCP_AUTO_UPDATE_ON_STARTUP=true
MCP_AUTO_UPDATE_TIMEOUT_SECONDS=45.0

# App Configuration
APP_NAME=PowerBI AI Hub
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]

# Other Settings
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
MAX_TOOL_CALLS_PER_MESSAGE=10
